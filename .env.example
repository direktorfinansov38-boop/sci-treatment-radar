# Scheduling
DIGEST_TIMEZONE=Asia/Ulaanbaatar
DIGEST_HOUR=10
DIGEST_MINUTE=0
DIGEST_LOOKBACK_DAYS=3
DIGEST_MAX_ITEMS=25

# AI summarization via Claude (Anthropic)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Telegram delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Generic webhook delivery
WEBHOOK_URL=

# Output folder for markdown digests
OUTPUT_DIR=digests

# Sent links/title memory. Keep this file persistent on your server.
STATE_PATH=state/sent_history.json
